#!/usr/bin/env python3
"""
pre-tool-use hook for Claude Code that blocks dangerous bash commands.

Place this file at ~/.claude/hooks/pre-tool-use and make it executable.
"""

import json
import os
import re
import sys
from datetime import datetime

LOG_FILE = os.path.expanduser("~/.claude/hooks/blocked.log")

DANGEROUS_PATTERNS = [
    re.compile(r'\brm\s+(?:-rf|--recursive|-r\s+-f)\b'),
    re.compile(r'\bmkfs\.'),
    re.compile(r'\bdd\s+if=.*\sof='),
    re.compile(r'\bshred\b'),
    re.compile(r'\bgit\s+push\s+(?:--force|-f|--force-with-lease)\b'),
    re.compile(r'\bDROP\s+(?:TABLE|DATABASE|SCHEMA)\b', re.IGNORECASE),
    re.compile(r'\bTRUNCATE\b', re.IGNORECASE),
    re.compile(r'\bDELETE\s+FROM\b(?!(?:.|\n)*\bWHERE\b)', re.IGNORECASE),
    re.compile(r'\bchmod\s+777\b'),
    re.compile(r'\bchown\s+-R\b'),
]

def check_command(cmd):
    for pattern in DANGEROUS_PATTERNS:
        if pattern.search(cmd):
            return True, f"Blocked dangerous pattern: {pattern.pattern}"
    return False, ""

def log_blocked(cmd, reason):
    os.makedirs(os.path.dirname(LOG_FILE), exist_ok=True)
    timestamp = datetime.now().isoformat()
    project_path = os.getcwd()
    entry = f"[{timestamp}] REASON: {reason}\n  COMMAND: {cmd}\n  PROJECT: {project_path}\n\n"
    try:
        with open(LOG_FILE, "a") as f:
            f.write(entry)
    except OSError:
        pass

def main():
    try:
        raw = sys.stdin.read()
    except Exception:
        sys.exit(0)
    if not raw or not raw.strip():
        sys.exit(0)
    try:
        call = json.loads(raw)
    except json.JSONDecodeError:
        sys.exit(0)
    tool = call.get("tool", "") if isinstance(call, dict) else ""
    if tool not in ("bash", "terminal", "Terminal", "Bash"):
        sys.exit(0)
    args = call.get("arguments", {}) if isinstance(call, dict) else {}
    cmd = args.get("command", "")
    if not cmd or not isinstance(cmd, str):
        sys.exit(0)
    blocked, reason = check_command(cmd)
    if blocked:
        log_blocked(cmd, reason)
        print(
            f"[HOOK BLOCKED] Command blocked — matches dangerous pattern:\n\n"
            f"  {cmd}\n\nReason: {reason}\n\n"
            f"Logged to: {LOG_FILE}",
            file=sys.stderr,
        )
        sys.exit(1)
    sys.exit(0)

if __name__ == "__main__":
    main()
